<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Market Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/dashboard.css">
</head>
<body>
    <header class="m_navbar">
        <div class="m_nav_name">
            <div class="m_name">Sustainable Discount Marketplace</div>
            <div class="m_img_cont"><img src="/img/leaf.png" alt="leaf" class="m_img"></div>
        </div>
        <div class="m_nav_func">
            <a class="m_dash active" href="#">Dashboard</a>
            <a class="m_prod" href="/market/addproduct">Add Products</a>
            <a id="m_prof" href="/profile/<%= market.id %>">
                <div class="m_img_cont"><img src="/img/userupdt.png" alt="user" class="m_img"></div>
                <div class="prof_name"><%= market.name %></div>
            </a>
            <a class="m_logout" href="/logout">Logout</a>
        </div>
    </header>

    <main class="m_dashboard">
        <div class="m_info">
            <div id="m_box_welc">
                <div class="m_box_img_cont"><img src="/img/box.png" alt="box" class="m_img"></div>
                <h2>Market Dashboard</h2>
            </div>
            <div class="m_info_welc">
                <span>Welcome Back, <span id="m_info_name"><%= market.name %></span>! Manage your inventory below.</span>
            </div>
            
            <div class="m_pro_num_info">
                <div class="m_stat_card">
                    <div class="m_stat_number text-green"><%= totalproduct %></div>
                    <div class="m_stat_label">TOTAL PRODUCTS</div>
                </div>
                <div class="m_stat_card">
                    <div class="m_stat_number text-green"><%= activeproduct %></div>
                    <div class="m_stat_label">ACTIVE</div>
                </div>
                <div class="m_stat_card">
                    <div class="m_stat_number text-red" id="m_stat_expired"><%= expiredproduct %></div>
                    <div class="m_stat_label">EXPIRED</div>
                </div>
                <div class="m_stat_card">
                    <div class="m_stat_number text-blue"><%= totalstock %></div>
                    <div class="m_stat_label">TOTAL STOCK</div>
                </div>
            </div>
            
            <div id="pro_inf_label"><h3>Your Products</h3></div>
        </div>

        <div class="m_products">
            <table>
                <thead class="m_pro_head">
                    <tr>
                        <th>IMAGE</th>
                        <th>TITLE</th>
                        <th>STOCK</th>
                        <th>PRICE</th>
                        <th>DISCOUNTED</th>
                        <th>EXPIRES</th>
                        <th>STATUS</th>
                        <th class="m_action_head">ACTION</th>
                    </tr>
                </thead>
                <tbody>
                    <% for( let p of product) { %>
                    <% if( p.isActive ) { %>  
                        <tr>
                    <% } else { %>
                        <tr class="expired_row">
                    <% } %>
                        <td><div class="m_img_cont m_prod_img"><img src="/uploads/<%= p.image_url  %>" alt="product image" class="m_img" ></div></td>
                        <td class="font-medium"><%= p.title %></td>
                        <td><%= p.stock %></td>
                        <td class="text-gray">₺<%= p.normal_price %></td>
                        <td class="text-success font-medium">₺<%= p.discounted_price %></td>
                        <td><%= new Date(p.expiration_date).toLocaleDateString('en-GB') %></td>
                        <% if( p.isActive ) { %>
                            <td><span class="m_pro_active">Active</span></td>
                        <% } else { %>
                            <td><span class="m_pro_expired">Expired</span></td>
                        <% } %>
                        <td>
                            <div class="m_action_container">
                                <a href="/market/product/edit/<%= p.id %>" class="m_prod_act"><img src="/img/edit.jpg" alt="edit"></a>
                                <a href="/market/product/delete/<%= p.id %>" class="m_prod_act"><img src="/img/delete.png" alt="delete"></a>
                            </div>
                        </td>
                    </tr>
                    <% } %>
                    </tbody>
            </table>
        </div>
    </main>
</body>
</html>