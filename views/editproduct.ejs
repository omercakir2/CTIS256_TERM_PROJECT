<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Product - Sustainable Market</title>
    <link rel="stylesheet" href="/bootstrap.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body {
            background-color: #e6e9ef;
            min-height: 100vh;
            font-family: 'Nunito', sans-serif;
            color: #444b40;
        }

        .navbar {
            background-color: #e6e9ef !important;
            box-shadow: 0 4px 10px rgba(184, 188, 194, 0.3);
        }

        .form-container {
            max-width: 850px;
            margin: 40px auto;
            padding: 3rem;
            background-color: #e6e9ef;
            border-radius: 30px;
            box-shadow: 20px 20px 60px #b8bcc2, -20px -20px 60px #ffffff;
        }

        .text-contrast {
            color: #2c3e50 !important;
        }

        .form-label {
            color: #2c3e50;
            font-weight: 700;
            margin-left: 10px;
            font-size: 0.9rem;
        }

        .form-control {
            background-color: #e6e9ef !important;
            border: none !important;
            border-radius: 15px !important;
            box-shadow: inset 4px 4px 8px #d1d9e6, inset -4px -4px 8px #ffffff !important;
            padding: 12px 18px;
            color: #2c3e50 !important;
            font-weight: 600;
        }

        /* Image Upload Box - Neumorphic Style */
        .image-upload-wrapper {
            position: relative;
            background-color: #e6e9ef;
            border-radius: 20px;
            padding: 20px;
            box-shadow: inset 5px 5px 10px #d1d9e6, inset -5px -5px 10px #ffffff;
            text-align: center;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .current-img-preview {
            width: 150px;
            height: 150px;
            object-fit: cover;
            border-radius: 15px;
            box-shadow: 5px 5px 10px #b8bcc2, -5px -5px 10px #ffffff;
            margin-bottom: 15px;
        }

        .file-input-custom {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
            z-index: 2;
        }

        .upload-hint {
            color: #7f8a99;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .btn-submit {
            background-color: #378dfc;
            border: none;
            border-radius: 50px;
            padding: 12px 30px;
            font-weight: 800;
            color: white !important;
            box-shadow: 5px 5px 12px rgba(55, 141, 252, 0.3);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-cancel {
            background-color: #e6e9ef;
            border: none;
            border-radius: 50px;
            padding: 12px 30px;
            font-weight: 700;
            color: #7f8a99 !important;
            box-shadow: 5px 5px 10px #b8bcc2, -5px -5px 10px #ffffff;
            text-decoration: none;
        }

        .btn-cancel:hover {
            box-shadow: inset 3px 3px 6px #b8bcc2, inset -3px -3px 6px #ffffff;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary" href="/market/dashboard">
                <span class="text-success">Green<span class="text-body">Markt</span> </span>
            </a>
            
            <div class="ms-auto d-flex align-items-center">
                <a class="btn btn-light btn-sm rounded-pill px-3 shadow-sm me-2" href="/market/dashboard">Dashboard</a>
                <a class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm me-2" href="/market/addproduct">Add Product</a>
                
                <a href="/market/profile/ class="d-flex align-items-center text-decoration-none ms-2">
                    <div class="rounded-circle bg-white shadow-sm d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                        <i class="bi bi-person-fill text-primary"></i>
                    </div>
                </a>
                <a class="btn btn-outline-danger btn-sm border-0 ms-3" href="/logout">Logout</a>
            </div>
        </div>
    </nav>

    <main class="container py-5">
        <div class="form-container">
            <div class="mb-5">
                <h2 class="fw-bold text-contrast">Edit Product</h2>
                <p class="text-muted">Update your product listing. Leave the image field empty to keep the current one.</p>
            </div>

            <form action="/market/editproduct/<%= product.id %>" method="POST" enctype="multipart/form-data">
                
                <div class="row mb-4">
                    <div class="col-md-8">
                        <label class="form-label">Product Title</label>
                        <input type="text" class="form-control" name="product_title" value="<%= product.title %>" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Stock Quantity</label>
                        <input type="number" class="form-control" name="product_stock" value="<%= product.stock %>" min="0" required>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-4">
                        <label class="form-label">Original Price (₺)</label>
                        <input type="number" class="form-control" name="original_price" value="<%= product.normal_price %>" step="0.01" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Discounted Price (₺)</label>
                        <input type="number" class="form-control" name="discounted_price" value="<%= product.discounted_price %>" step="0.01" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Expiration Date</label>
                        <input type="date" class="form-control" name="expire_date" value="<%= new Date(product.expiration_date).toLocaleDateString('en-CA') %>" required>
                    </div>
                </div>

                <div class="mb-5">
                    <label class="form-label d-block mb-3">Product Image</label>
                    <div class="image-upload-wrapper">
                        <img src="/uploads/<%= product.image_url %>" alt="Current image" class="current-img-preview">
                        <div class="py-2">
                            <i class="bi bi-cloud-arrow-up text-primary fs-2"></i>
                            <p class="mb-1 fw-bold text-contrast">Click to change image</p>
                            <span class="upload-hint">Supported formats: JPG, PNG</span>
                        </div>
                        <input type="hidden" name="product_image_already" value="<%= product.image_url %>">
                        <input type="file" class="file-input-custom" name="product_image" accept="image/png, image/jpeg">
                    </div>
                </div>

                <% if (locals.infoMsg && locals.infoMsg !== "") { %>
                    <div class="alert <%= locals.infoMsgStatus ? 'alert-success' : 'alert-danger' %> border-0 rounded-4 py-3 mb-4 text-center fw-bold">
                        <%= locals.infoMsg %>
                    </div>
                <% } %>

                <div class="d-flex justify-content-end gap-3 mt-5">
                    <a href="/market/dashboard" class="btn-cancel">Cancel</a>
                    <button type="submit" class="btn-submit btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </main>

    <footer class="py-5 text-center text-muted">
        <small>&copy; 2026 Sustainable Market Dashboard</small>
    </footer>

</body>
</html>