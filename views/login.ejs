<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login</title>
    <link rel="stylesheet" href="bootstrap.css">
</head>
<body class="bg-primary bg-gradient d-flex align-items-center justify-content-center vh-100">

    <div class="card shadow border-0 rounded-5 p-4" style="width: 100%; max-width: 400px;">
        <div class="card-body">
           
            <h2 class="text-center mb-4">Login</h2>
            <form method="POST" action="/login" novalidate>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" name="email" value="<%= typeof formData !== 'undefined' ? formData.email : '' %>">
                </div>
                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <input type="password" class="form-control" name="password" value="<%= typeof formData !== 'undefined' ? formData.password : '' %>">
                </div>
                <button type="submit" class="btn btn-success w-100 rounded-pill mb-3">Log In</button>
                <% if (error) { %>
                <div class="alert alert-danger text-center py-2 mb-3 rounded-pill" role="alert" style="font-size: 0.9rem;">
                    <%= error %>
                </div>
                <% } %>
                
                <div class="text-center">
                    <a href="/register" class="text-success text-decoration-none small">Sign Up</a>
                </div>
            </form>
        </div>
    </div>

</body>
</html>