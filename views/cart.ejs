<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shopping Cart</title>

    <link rel="stylesheet" href="bootstrap.css">
    <style>
        body {
            background-color: #d9e3f1; /* Theme default background */
            min-height: 100vh;
            font-family: 'Nunito', sans-serif;
        }
        
        .cart-wrapper {
            max-width: 900px;
            margin: 60px auto;
        }

        /* Soft Neumorphic Card */
        .cart-card {
            border: none;
            background-color: #d9e3f1;
            border-radius: 2rem;
            box-shadow: 10px 10px 20px rgba(55, 94, 148, 0.2), 
                        -10px -10px 20px rgba(255, 255, 255, 0.5);
            padding: 2.5rem;
        }

        .product-img {
            width: 90px;
            height: 90px;
            object-fit: cover;
            border-radius: 1.25rem;
            /* Inner shadow for the "pressed" look on images */
            box-shadow: inset 2px 2px 5px rgba(55, 94, 148, 0.3), 
                        inset -3px -2px 5px rgba(255, 255, 255, 0.8);
        }

        .summary-box {
            background-color: #f0f5fa;
            border-radius: 1.5rem;
            box-shadow: inset 2px 2px 8px rgba(55, 94, 148, 0.1);
        }

        .navbar {
            background-color: #d9e3f1;
            padding: 1rem 0;
        }
    </style>
</head>
<body>


<nav class="navbar navbar-expand-lg navbar-light shadow-sm sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold fs-4" href="#">
            <span class="text-primary">SUSTANINABLE</span>MARKET
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
            <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link px-3" href="/main">Shop</a></li>
            </ul>
            <div class="d-flex align-items-center">
                <button class="btn btn-secondary rounded-pill px-4 fw-bold">
                    Cart <span class="badge bg-danger rounded-pill">2</span>
                </button>
                <a href="/logout">
                    <button class="btn btn-secondary rounded-pill px-4 fw-bold">Logout</button>
                </a>
            </div>
        </div>
    </div>
</nav>

<!-- Cart Section -->
<div class="container cart-wrapper">
    <div class="cart-card">
        <div class="row">
            <!-- Items Column -->
            <div class="col-lg-8 pe-lg-5">
                <h2 class="fw-bold mb-5 text-dark">Shopping Cart</h2>
                
                <!-- Item 1 -->
                <div class="d-flex align-items-center justify-content-between mb-4 pb-4 border-bottom border-secondary-subtle">
                    <div class="d-flex align-items-center">
                        <img src="https://via.placeholder.com/90" alt="Product" class="product-img me-4">
                        <div>
                            <h5 class="mb-1 fw-bold">Premium Headphones</h5>
                            <p class="small text-muted mb-0">Noise Cancelling, Matte Black</p>
                            <div class="mt-2">
                                <span class="badge bg-light text-dark border me-2">Qty: 1</span>
                                <a href="#" class="text-danger text-decoration-none small fw-bold">Remove</a>
                            </div>
                        </div>
                    </div>
                    <div class="text-end">
                        <span class="fw-bold fs-5 text-primary">$299.00</span>
                    </div>
                </div>

                <!-- Item 2 -->
                <div class="d-flex align-items-center justify-content-between mb-4 pb-4 border-bottom border-secondary-subtle">
                    <div class="d-flex align-items-center">
                        <img src="https://via.placeholder.com/90" alt="Product" class="product-img me-4">
                        <div>
                            <h5 class="mb-1 fw-bold">Mechanical Keyboard</h5>
                            <p class="small text-muted mb-0">RGB Lighting, Brown Switches</p>
                            <div class="mt-2">
                                <span class="badge bg-light text-dark border me-2">Qty: 1</span>
                                <a href="#" class="text-danger text-decoration-none small fw-bold">Remove</a>
                            </div>
                        </div>
                    </div>
                    <div class="text-end">
                        <span class="fw-bold fs-5 text-primary">$149.00</span>
                    </div>
                </div>

                <div class="mt-3">
                    <a href="#" class="text-secondary text-decoration-none small fw-bold">← Continue Shopping</a>
                </div>
            </div>

            <!-- Summary Column -->
            <div class="col-lg-4 mt-5 mt-lg-0">
                <div class="summary-box p-4">
                    <h4 class="fw-bold mb-4">Summary</h4>
                    
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal</span>
                        <span class="fw-semibold">$448.00</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Shipping</span>
                        <span class="text-success fw-bold">Free</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="text-muted">Taxes</span>
                        <span class="fw-semibold">$35.00</span>
                    </div>
                    
                    <hr class="my-4">
                    
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="fs-5 fw-bold">Total</span>
                        <span class="fs-3 fw-bold text-primary">$483.00</span>
                    </div>
                    
                    <button class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow">
                        Checkout Now
                    </button>
                </div>
                
                <p class="text-center text-muted small mt-3">
                    Secure 256-bit SSL encrypted checkout.
                </p>
            </div>
        </div>
    </div>
</div>

</body>
</html>