<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

     <link rel="stylesheet" href="bootstrap.css">
  

     <style>
        body {
    background-color: #f8f9fa;
}

.card-img-top {
    height: 180px;
    object-fit: cover;
}

.card {
    border-radius: 12px;
}

.card:hover {
    transform: translateY(-3px);
    transition: 0.2s;
}

.navbar-brand {
    color: #198754;
}
     </style>
</head>
<body>

      <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
    <div class="container">
        <a class="navbar-brand fw-bold" href="#">Sustainable Market</a>

        <div class="ms-auto">
            <a href="#" class="btn btn-outline-secondary btn-sm">Cart</a>
            <a href="#" class="btn btn-outline-danger btn-sm">Logout</a>
        </div>
    </div>
</nav>
    <div class="row mb-4">
    <div class="col-lg-10 mx-auto"></div>">
        <h2>Welcome, Eren</h2>
        <p class="text-muted mb-1">Find discounted products near you.</p>
        <p class="mb-0">
            <span class="badge bg-secondary">City: Ankara</span>
            <span class="badge bg-secondary">District: Bilkent</span>
        </p>
    </div>
</div>


<div class="row mb-4">
    <div class="col">
        <form>
            <div class="input-group">
                <input 
                    type="text" 
                    class="form-control" 
                    placeholder="Search products, e.g. magnum, milk, bread"
                >
                <button class="btn btn-primary" type="submit">
                    Search
                </button>
            </div>
        </form>
    </div>
</div>

<div class="row mb-3 justify-content-center">
    <div class="col-md-8 text-center">
        <h4>Available Products</h4>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
    <div class="card h-100">

        <img src="img/magnumClassic.jpg" class="card-img-top" alt="product">

        <div class="card-body d-flex flex-column">

            <h5 class="card-title">Magnum Classic</h5>

            <p class="mb-1 text-muted">Tok Market - Bilkent</p>

            <span class="badge bg-success mb-2">Same District</span>

            <p class="mb-1">
                <span class="text-decoration-line-through text-muted">200 TL</span>
                <span class="fw-bold text-danger ms-2">120 TL</span>
            </p>

            <p class="mb-2 text-muted">Expires: 22-05-2026</p>

            <p class="text-success mb-3">21 days left</p>

            <button class="btn btn-primary mt-auto">
                Add to Cart
            </button>

        </div>
    </div>
</div>
<div class="col-12 col-sm-6 col-md-4 col-lg-3">
    <div class="card h-100">

        <img src="img/nutella.jpeg" class="card-img-top" alt="product">

        <div class="card-body d-flex flex-column">

            <h5 class="card-title">Nutella</h5>

            <p class="mb-1 text-muted">Tok Market - Bilkent</p>

            <span class="badge bg-success mb-2">Same District</span>

            <p class="mb-1">
                <span class="text-decoration-line-through text-muted">300 TL</span>
                <span class="fw-bold text-danger ms-2">220 TL</span>
            </p>

            <p class="mb-2 text-muted">Expires: 22-05-2026</p>

            <p class="text-success mb-3">21 days left</p>

            <button class="btn btn-primary mt-auto">
                Add to Cart
            </button>

        </div>
    </div>
</div>

<div class="col-12 col-sm-6 col-md-4 col-lg-3">
    <div class="card h-100">

        <img src="img/süt.png" class="card-img-top" alt="product">

        <div class="card-body d-flex flex-column">

            <h5 class="card-title">Milk</h5>

            <p class="mb-1 text-muted">Tok Market - Bilkent</p>

            <span class="badge bg-success mb-2">Same District</span>

            <p class="mb-1">
                <span class="text-decoration-line-through text-muted">100 TL</span>
                <span class="fw-bold text-danger ms-2">70 TL</span>
            </p>

            <p class="mb-2 text-muted">Expires: 22-05-2026</p>

            <p class="text-success mb-3">21 days left</p>

            <button class="btn btn-primary mt-auto">
                Add to Cart
            </button>

        </div>
    </div>
</div>

<div class="col-12 col-sm-6 col-md-4 col-lg-3">
    <div class="card h-100">

        <img src="img/ekmek.jpeg" class="card-img-top" alt="product">

        <div class="card-body d-flex flex-column">

            <h5 class="card-title">Bread</h5>

            <p class="mb-1 text-muted">Tok Market - Bilkent</p>

            <span class="badge bg-success mb-2">Same District</span>

            <p class="mb-1">
                <span class="text-decoration-line-through text-muted">50 TL</span>
                <span class="fw-bold text-danger ms-2">20 TL</span>
            </p>

            <p class="mb-2 text-muted">Expires: 22-05-2026</p>

            <p class="text-success mb-3">21 days left</p>

            <button class="btn btn-primary mt-auto">
                Add to Cart
            </button>

        </div>
    </div>
</div>
    
</div>

<nav class="mt-4">
    <ul class="pagination justify-content-center">

        <li class="page-item disabled">
            <a class="page-link" href="#">Previous</a>
        </li>

        <li class="page-item active">
            <a class="page-link" href="#">1</a>
        </li>

        <li class="page-item">
            <a class="page-link" href="#">2</a>
        </li>

        <li class="page-item">
            <a class="page-link" href="#">3</a>
        </li>

        <li class="page-item">
            <a class="page-link" href="#">Next</a>
        </li>

    </ul>
</nav>

  

<footer class="bg-light border-top mt-5 py-3">
    <div class="container text-center text-muted">
        <small>&copy; 2026 Sustainable Market. All rights reserved.</small>
    </div>
</footer>

    
