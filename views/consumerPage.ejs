<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <link rel="stylesheet" href="bootstrap.css">


    <style>
        body {
            background-color: #f8f9fa;
        }

        .card-img-top {
            height: 180px;
            object-fit: cover;
        }

        .card {
            border-radius: 12px;
        }

        .card:hover {
            transform: translateY(-3px);
            transition: 0.2s;
        }

        .navbar-brand {
            color: #198754;
        }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">Sustainable Market</a>

            <div class="ms-auto">
                <a href="/cart" class="btn btn-outline-secondary btn-sm">Cart</a>
                <a href="/logout" class="btn btn-outline-danger btn-sm">Logout</a>
            </div>
        </div>
    </nav>
    <div class="row mb-4">
        <div class="col-lg-10 mx-auto"></div>">
        <h2>Welcome, <%= user.name %>
        </h2>
        <p class="text-muted mb-1">Find discounted products near you.</p>
        <p class="mb-0">
            <span class="badge bg-secondary">City: <%= user.city %> </span>
            <span class="badge bg-secondary">District: <%= user.district %></span>
        </p>
    </div>
    </div>


    <div class="row mb-4">
        <div class="col">
            <form action="/main" method="GET">
                <div class="input-group">
                    <input type="text" class="form-control" placeholder="Search products, e.g. magnum, milk, bread" name="keyword" value="<%= keyword || '' %>">
                    <button class="btn btn-primary" type="submit">
                        Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="row mb-3 justify-content-center">
        <div class="col-md-8 text-center">
            <h4>Available Products</h4>
        </div>
    </div>

    <% if (products.length === 0) { %>
    <div class="alert alert-warning">
        No products found.
    </div>
<% } else{ %>

    <div class="row g-4">
        <% for( let p of products ) { %>
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100">

                    <img src="img/<%= p.image_url %>" class="card-img-top" alt="product">

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title">
                            <%= p.title %>
                        </h5>

                        <p class="mb-1 text-muted">
                            <%= p.market %> - <%= p.district %>
                        </p>
                        
                       <% if (p.isSameDistrict) { %>
            <span class="badge bg-success mb-2">Same District</span>
                        <% } %>

                        <p class="mb-1">
                            <span class="text-decoration-line-through text-muted">
                                <%= p.normal_price %> TL
                            </span>
                            <span class="fw-bold text-danger ms-2">
                                <%= p.discounted_price %> TL
                            </span>
                        </p>

                        <p class="mb-2 text-muted">Expires: <%= p.formattedExpirationDate %>
                        </p>

                        <% if (p.daysLeft === 0) { %>
                         <p class="days-left mb-3">Expires today</p>
                            <% } else { %>
                         <p class="days-left mb-3"><%= p.daysLeft %> days left</p>
                            <% } %>
                        <a href="/cart/add/product/<%= p.id %>">
                            <button class="btn btn-primary mt-auto">
                                Add to Cart
                            </button>
                        </a>

                    </div>
                </div>
            </div>
            <% } %>

    </div>

    <% } %>

   <% if (totalPages > 1) { %>
    <nav class="mt-4">
        <ul class="pagination justify-content-center">

            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                <a class="page-link" href="/main?keyword=<%= keyword %>&page=<%= currentPage - 1 %>">
                    Previous
                </a>
            </li>

            <% for (let i = 1; i <= totalPages; i++) { %>
                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                    <a class="page-link" href="/main?keyword=<%= keyword %>&page=<%= i %>">
                        <%= i %>
                    </a>
                </li>
            <% } %>

            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                <a class="page-link" href="/main?keyword=<%= keyword %>&page=<%= currentPage + 1 %>">
                    Next
                </a>
            </li>

        </ul>
    </nav>
<% } %>



    <footer class="bg-light border-top mt-5 py-3">
        <div class="container text-center text-muted">
            <small>&copy; 2026 Sustainable Market. All rights reserved.</small>
        </div>
    </footer>


</body>

</html>