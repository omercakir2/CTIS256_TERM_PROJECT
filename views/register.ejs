<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register</title>
    <link rel="stylesheet" href="bootstrap.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body {
            background-color: #e6e9ef;
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .register-card {
            background-color: #e6e9ef;
            border: none;
            border-radius: 40px;
            /* Neumorphic Shadows */
            box-shadow: 18px 18px 35px , -18px -18px 35px #ffffff;
            width: 100%;
            max-width: 550px;
            padding: 2.5rem;
            margin: 2rem 0;
        }

        .title-text {
            font-weight: 800;
            color: #2c3e50 !important;
            margin-bottom: 1.5rem;
        }

        .form-label {
            color: #2c3e50;
            font-weight: 700;
            margin-left: 8px;
            font-size: 0.9rem;
        }

        .form-control {
            background-color: #e6e9ef !important;
            border: none !important;
            border-radius: 15px !important;
            box-shadow: inset 4px 4px 8px #d1d9e6, inset -4px -4px 8px #ffffff !important;
            padding: 12px 18px;
            color: #2c3e50 !important;
            font-weight: 600;
        }

        /* Role Selection Buttons */
        .btn-check:checked + .btn-outline-secondary {
            background-color: #378dfc !important;
            color: white !important;
            border-color: transparent !important;
            box-shadow: 4px 4px 10px #b8bcc2 !important;
        }

        .btn-outline-secondary {
            border: none !important;
            background-color: #e6e9ef;
            color: #7b8ab8;
            border-radius: 15px !important;
            box-shadow: 5px 5px 10px #d1d9e6, -5px -5px 10px #ffffff;
            font-weight: 700;
            transition: all 0.3s ease;
        }

        .btn-register {
            background-color: #378dfc;
            border: none;
            border-radius: 50px;
            padding: 14px;
            font-weight: 700;
            color: white !important;
            box-shadow: 5px 5px 12px #b8bcc2, -5px -5px 12px #ffffff;
            margin-top: 1rem;
            transition: all 0.3s ease;
        }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 8px 8px 18px #b8bcc2, -8px -8px 18px #ffffff;
            background-color: #2e7ae0;
        }

        .alert-error {
            background-color: #fceae9;
            color: #e52527;
            border: none;
            font-weight: 600;
            border-radius: 15px;
        }
    </style>
</head>
<body>

    <div class="register-card text-center">
        <h2 class="title-text">Register</h2>
        
        <form method="POST" action="/register" novalidate>
            <div class="row g-3 mb-4">
                <div class="col-6">
                    <input type="radio" class="btn-check" name="role" id="consumer" value="consumer" checked onchange="toggleRole()">
                    <label class="btn btn-outline-secondary w-100 py-3" for="consumer">
                        <i class="bi bi-person me-2"></i>Consumer
                    </label>
                </div>
                <div class="col-6">
                    <input type="radio" class="btn-check" name="role" id="market" value="market" onchange="toggleRole()">
                    <label class="btn btn-outline-secondary w-100 py-3" for="market">
                        <i class="bi bi-shop me-2"></i>Market
                    </label>
                </div>
            </div>

            <div class="mb-3 text-start">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" name="email" value="<%= typeof formData !== 'undefined' ? formData.email : '' %>">
            </div>

            <div class="row g-3 mb-3 text-start">
                <div class="col-md-6">
                    <label class="form-label">Password</label>
                    <input type="password" class="form-control" name="password" value="<%= typeof formData !== 'undefined' ? formData.password : '' %>">
                </div>
                <div class="col-md-6">
                    <label class="form-label">Confirm Password</label>
                    <input type="password" class="form-control" name="confirmPassword" value="<%= typeof formData !== 'undefined' ? formData.confirmPassword : '' %>">
                </div>
            </div>

            <div class="row g-3 mb-3 text-start">
                <div class="col-md-6">
                    <label class="form-label">City</label>
                    <input type="text" class="form-control" name="city" value="<%= typeof formData !== 'undefined' ? formData.city : '' %>">
                </div>
                <div class="col-md-6">
                    <label class="form-label">District</label>
                    <input type="text" class="form-control" name="district" value="<%= typeof formData !== 'undefined' ? formData.district : '' %>">
                </div>
            </div>

            <div id="marketField" class="mb-4 text-start">
                <label class="form-label" id="nameLabel">Full Name</label>
                <input type="text" class="form-control" name="name" value="<%= typeof formData !== 'undefined' ? formData.name : '' %>">
            </div>

            <% if (error) { %>
            <div class="alert alert-error text-center py-2 mb-3 shadow-none" role="alert">
                <i class="bi bi-exclamation-circle me-1"></i> <%= error %>
            </div>
            <% } %>

            <button type="submit" class="btn btn-register w-100 mb-3">
                Create Account
            </button>
            
            <div class="text-center pt-2">
                <span class="text-muted small">Already have an account?</span>
                <a href="/login" class="text-primary fw-bold text-decoration-none small ms-1">Log In</a>
            </div>
        </form>
    </div>

    <script>
        function toggleRole() {
            const isMarket = document.getElementById('market').checked;
            const nameLabel = document.getElementById('nameLabel');
            if (isMarket) {
                nameLabel.innerHTML = "Market Name";
            } else {
                nameLabel.innerHTML = "Full Name";
            }
        }
    </script>
</body>
</html>