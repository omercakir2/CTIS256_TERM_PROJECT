<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile</title>

    <link rel="stylesheet" href="/bootstrap.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body {
            background-color: #e6e9ef;
            min-height: 100vh;
            font-family: 'Nunito', sans-serif;
            color: #444b40;
        }

        .navbar {
            background-color: #e6e9ef !important;
            box-shadow: 0 4px 10px rgba(184, 188, 194, 0.3);
        }

        .profile-card {
            background-color: #e6e9ef;
            border: none;
            border-radius: 2.5rem;
            /* Morph Neumorphic Shadows */
            box-shadow: 15px 15px 30px #b8bcc2, -15px -15px 30px #ffffff;
            padding: 2.5rem;
        }

        .text-contrast {
            color: #2c3e50 !important;
        }

        .form-label {
            color: #2c3e50;
            font-weight: 700;
            margin-left: 8px;
            font-size: 0.9rem;
        }

        .form-control {
            background-color: #e6e9ef !important;
            border: none !important;
            border-radius: 15px !important;
            /* Inset shadow for inputs */
            box-shadow: inset 4px 4px 8px #d1d9e6, inset -4px -4px 8px #ffffff !important;
            padding: 12px 18px;
            color: #2c3e50 !important;
            font-weight: 600;
        }

        .form-control:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            box-shadow: none !important;
            background-color: rgba(0, 0, 0, 0.02) !important;
        }

        .btn-save {
            background-color: #378dfc;
            border: none;
            border-radius: 50px;
            padding: 14px;
            font-weight: 800;
            color: white !important;
            box-shadow: 5px 5px 12px rgba(55, 141, 252, 0.3);
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
        }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 8px 8px 18px rgba(55, 141, 252, 0.4);
        }

        .alert {
            border: none;
            border-radius: 15px;
            font-weight: 600;
        }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4 text-primary"
                href="<%= user.role === 'consumer' ? '/main' : '/market/dashboard' %>">
                <span class="text-success">Green<span class="text-body">Markt</span> </span>

            </a>

            <div class="ms-auto d-flex align-items-center">
                <% if (user.role==='consumer' ) { %>
                    <a href="/main" class="btn btn-light btn-sm rounded-pill px-3 shadow-sm me-2">Main Page</a>
                    <a href="/cart" class="btn btn-light btn-sm rounded-pill px-3 shadow-sm me-2">Cart</a>
                    <% } else { %>
                        <a href="/market/dashboard"
                            class="btn btn-light btn-sm rounded-pill px-3 shadow-sm me-2">Dashboard</a>
                        <% } %>
                            <a href="/logout" class="btn btn-outline-danger btn-sm border-0 ms-2">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <div class="profile-card">
                    <div class="text-center mb-4">
                        <div class="display-4 text-primary mb-2">
                            <i class="bi bi-person-gear"></i>
                        </div>
                        <h3 class="fw-bold text-contrast mb-1">
                            <%= user.role==='consumer' ? 'Edit Consumer Profile' : 'Edit Market Profile' %>
                        </h3>
                        <p class="text-muted">
                            Update your account information.
                        </p>
                    </div>

                    <% if (error) { %>
                        <div class="alert alert-danger text-center mb-4 py-2">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <%= error %>
                        </div>
                        <% } %>

                            <% if (success) { %>
                                <div class="alert alert-success text-center mb-4 py-2">
                                    <i class="bi bi-check-circle-fill me-2"></i>
                                    <%= success %>
                                </div>
                                <% } %>

                                    <form
                                        action="<%= user.role === 'consumer' ? '/consumer/profile' : '/market/profile' %>"
                                        method="POST">

                                        <div class="mb-4">
                                            <label class="form-label">
                                                <%= user.role==='consumer' ? 'Full Name' : 'Market Name' %>
                                            </label>
                                            <input type="text" name="name" class="form-control"
                                                value="<%= formData.name || '' %>" maxlength="20"
                                                placeholder="Enter name">
                                        </div>

                                        <div class="mb-4">
                                            <label class="form-label">Email Address</label>
                                            <input type="email" class="form-control" value="<%= user.email %>" disabled>
                                            <div class="ms-2 mt-1">
                                                <small class="text-muted"><i class="bi bi-info-circle me-1"></i>Email
                                                    cannot be changed.</small>
                                            </div>
                                        </div>

                                        <div class="row mb-4">
                                            <div class="col-6">
                                                <label class="form-label">City</label>
                                                <input type="text" name="city" class="form-control"
                                                    value="<%= formData.city || '' %>" maxlength="20"
                                                    placeholder="City">
                                            </div>
                                            <div class="col-6">
                                                <label class="form-label">District</label>
                                                <input type="text" name="district" class="form-control"
                                                    value="<%= formData.district || '' %>" maxlength="20"
                                                    placeholder="District">
                                            </div>
                                        </div>

                                        <button type="submit" class="btn btn-save btn-primary w-100 mt-2">
                                            Save Changes <i class="bi bi-save2 ms-2"></i>
                                        </button>

                                    </form>
                </div>

                <div class="text-center mt-4">
                    <a href="javascript:history.back()" class="text-decoration-none fw-bold small text-primary">
                        <i class="bi bi-arrow-left me-1"></i> Go Back
                    </a>
                </div>

            </div>
        </div>
    </div>

</body>

</html>