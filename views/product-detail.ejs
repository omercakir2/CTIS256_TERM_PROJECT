<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.title %> - Sustainable Market</title>
    <link rel="stylesheet" href="/bootstrap.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body {
            background-color: #e6e9ef;
            min-height: 100vh;
            font-family: 'Nunito', sans-serif;
            color: #444b40;
        }

        .navbar {
            background-color: #e6e9ef !important;
            box-shadow: 0 4px 10px rgba(184, 188, 194, 0.3);
        }

        /* Product Image Card */
        .product-img-card {
            background-color: #e6e9ef;
            border: none;
            border-radius: 30px;
            box-shadow: 15px 15px 30px #b8bcc2, -15px -15px 30px #ffffff;
            padding: 1.2rem;
        }

        .product-main-img {
            width: 100%;
            height: auto;
            border-radius: 20px;
            box-shadow: inset 5px 5px 10px #d1d9e6, inset -5px -5px 10px #ffffff;
        }

        /* Details Card */
        .product-details-card {
            background-color: #e6e9ef;
            border: none;
            border-radius: 30px;
            box-shadow: 15px 15px 30px #b8bcc2, -15px -15px 30px #ffffff;
            padding: 2.5rem;
        }

        .text-dark-contrast {
            color: #2c3e50 !important;
        }

        /* Price Area */
        .price-container {
            background-color: #e6e9ef;
            border-radius: 20px;
            padding: 1.5rem;
            box-shadow: inset 4px 4px 8px #d1d9e6, inset -4px -4px 8px #ffffff;
            margin: 1.5rem 0;
        }

        .old-price {
            text-decoration: line-through;
            color: #7f8a99;
            font-size: 1.1rem;
        }

        .new-price {
            color: #378dfc;
            font-weight: 800;
            font-size: 2rem;
        }

        .btn-add-cart {
            background-color: #378dfc;
            color: white !important;
            border: none;
            border-radius: 50px;
            padding: 15px 30px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 6px 6px 15px rgba(55, 141, 252, 0.3);
            transition: all 0.3s ease;
            width: 100%;
        }

        .btn-add-cart:hover {
            transform: translateY(-3px);
            box-shadow: 8px 8px 20px rgba(55, 141, 252, 0.4);
        }

        .info-row {
            display: flex;
            align-items: center;
            margin-bottom: 0.75rem;
            color: #5d6d7e;
            font-weight: 600;
        }

        .info-row i {
            width: 25px;
            color: #378dfc;
        }

        .badge-near-you {
            background-color: #43cc29;
            color: white;
            padding: 8px 16px;
            border-radius: 50px;
            font-weight: 700;
            box-shadow: 0 4px 10px rgba(67, 204, 41, 0.3);
            display: inline-block;
        }
        .badge-out-of-stock {
            background-color: red;
            color: white;
            padding: 8px 16px;
            border-radius: 50px;
            font-weight: 700;
            box-shadow: 0 4px 10px rgba(67, 204, 41, 0.3);
            display: inline-block;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4 text-primary" href="/main">
                <i class="bi bi-leaf-fill me-2"></i>SUSTAINABLE MARKET
            </a>

            <div class="ms-auto d-flex align-items-center">
                <a href="/main" class="btn btn-light btn-sm rounded-pill px-3 shadow-sm me-2">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
                <a href="/cart" class="btn btn-light btn-sm rounded-pill px-3 shadow-sm me-2">
                    <i class="bi bi-cart3 me-1"></i> Cart
                </a>
                <a href="/logout" class="btn btn-outline-danger btn-sm border-0 ms-2">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row g-5">

            <div class="col-lg-5">
                <div class="product-img-card text-center">
                    <img src="/uploads/<%= product.image_url || '/placeholder.jpg' %>" 
                         class="product-main-img" 
                         alt="<%= product.title %>">
                </div>
            </div>

            <div class="col-lg-7">
                <div class="product-details-card">
                    
                    <div class="mb-4">
                        <% if (product.isSameDistrict) { %>
                            <span class="badge-near-you"><i class="bi bi-geo-alt-fill me-1"></i>Near You</span>
                        <% } %>
                        <% if (product.stock <= 0) { %>
                            <span class="badge-out-of-stock">No Stock!</span>
                        <% } %>
                    </div>

                    <h1 class="fw-bold text-dark-contrast mb-2"><%= product.title %></h1>
                    
                    <p class="text-primary fw-bold mb-4">
                        <i class="bi bi-shop me-2"></i>Sold by: <%= product.market %>
                    </p>

                    <div class="info-list mb-4">
                        <div class="info-row">
                            <i class="bi bi-geo-alt"></i>
                            <span>Location: <%= product.city %> / <%= product.district %></span>
                        </div>
                        <div class="info-row">
                            <i class="bi bi-box-seam"></i>
                            <span>Stock: <span class="text-dark-contrast"><%= product.stock %> items left</span></span>
                        </div>
                        <div class="info-row">
                            <i class="bi bi-calendar-event"></i>
                            <span>Expires: <%= product.formattedExpirationDate %></span>
                        </div>
                        <div class="info-row">
                            <i class="bi bi-clock-history"></i>
                            <span class="<%= product.daysLeft === 0 ? 'text-danger fw-bold' : '' %>">
                                <%= product.daysLeft === 0 ? 'Expires today' : product.daysLeft + ' days left' %>
                            </span>
                        </div>
                    </div>

                    <div class="price-container d-flex align-items-center">
                        <div class="flex-grow-1">
                            <div class="old-price"><%= product.normal_price %> TL</div>
                            <div class="new-price"><%= product.discounted_price %> TL</div>
                        </div>
                        <div class="text-end">
                            <span class="badge bg-danger rounded-pill px-3 py-2 fw-bold">
                                %<%= Math.round((1 - product.discounted_price/product.normal_price) * 100) %> OFF
                            </span>
                        </div>
                    </div>

                    <div class="mt-4">
                        <% if(product.stock <=0) {%>
                            <span class="btn btn-add-cart">
                                <i class="bi bi-cart-plus-fill me-2"></i> No Stock
                            </span>
                            <%}else{%>
                                <a href="/cart/add/product/<%= product.id %>" class="btn btn-add-cart">
                                    <i class="bi bi-cart-plus-fill me-2"></i> Add to Cart
                                </a>
                                <%}%>
                    </div>

                    <div class="text-center mt-4">
                        <small class="text-muted"><i class="bi bi-shield-check me-1"></i> Quality and Sustainability Guaranteed</small>
                    </div>

                </div>
            </div>

        </div>
    </div>

    <footer class="py-5 text-center text-muted border-top mt-5">
        <small>&copy; 2026 Sustainable Market. Saving the planet, one product at a time.</small>
    </footer>

</body>
</html>